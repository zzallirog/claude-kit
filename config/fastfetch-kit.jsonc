{
  // kit-claude fastfetch config — system info + command reminders at startup.
  // Installed to ~/.config/fastfetch/config.jsonc (the old file is backed up).
  "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",
  "logo": { "type": "auto", "padding": { "top": 1 } },
  "display": { "separator": "  " },
  "modules": [
    "title",
    "separator",
    { "type": "os",     "key": "OS    " },
    { "type": "kernel", "key": "Kernel" },
    { "type": "cpu",    "key": "CPU   " },
    { "type": "gpu",    "key": "GPU   " },
    { "type": "memory", "key": "Memory" },
    { "type": "disk",   "key": "Disk  ", "folders": "/" },
    "break",
    { "type": "custom", "format": "──── commands (what does what) ────" },
    { "type": "custom", "format": "  update      update the system + security check" },
    { "type": "custom", "format": "  fix         repair: disk · DNS · Wi-Fi · packages · services" },
    { "type": "custom", "format": "  where       laptop map (what lives where)" },
    { "type": "custom", "format": "  recall X    search notes + logs" },
    { "type": "custom", "format": "  kit-guide   nice dossier in the browser (or Super+\\)" },
    { "type": "custom", "format": "  kit-help    cheatsheet   ·   claude  — ask the AI" },
    "break",
    { "type": "custom", "format": "  root: only with your password. you decide · Opus thinks · Sonnet acts" },
    "break"
  ]
}
